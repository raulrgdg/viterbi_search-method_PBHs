# Direct HTCondor submit file for the SFT strong-scaling benchmark.
# Usage from studies/strong_scaling:
#   condor_submit job_make_SFT_SS_test.sub

executable = /bin/bash
initialdir = .

arguments = run_make_SFT-SS_test_condor.sh data/framecache_raw_strain_512HZ 16 32 64 128 256 512

output = condor_logs/make_sft_ss_test.$(ClusterId).out
error = condor_logs/make_sft_ss_test.$(ClusterId).err
log = condor_logs/make_sft_ss_test.$(ClusterId).log

request_cpus = 8
request_memory = 1GB
request_disk = 5GB

accounting_group = ligo.dev.o4.cw.transient.viterbi
accounting_group_user = raul.rodriguez

getenv = True
on_exit_hold = (ExitBySignal == True) || (ExitCode != 0)

queue 1
